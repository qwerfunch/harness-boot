#!/usr/bin/env node
// F-110 — single-file bundle entry. Loads the esbuild-produced bundle
// at dist/cli/harness.bundle.mjs which inlines every runtime dep
// (commander, yaml, ajv, ajv-formats, smol-toml). No `npm install`
// required at the install site — Claude Code's plugin install copies
// dist/ alongside this shim and the `bin/` directory is auto-added to
// PATH per the plugin spec.
import {dirname, join} from 'node:path';
import {fileURLToPath} from 'node:url';
const here = dirname(fileURLToPath(import.meta.url));
const bundle = join(here, '..', 'dist', 'cli', 'harness.bundle.mjs');
const mod = await import(bundle);
mod.main(process.argv);
