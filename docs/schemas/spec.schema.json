{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://harness-boot.dev/schemas/spec.schema.json",
  "title": "harness-boot spec.yaml",
  "description": "v2.3.8 — metadata.* 8 블록 승격 (v2.3.7 metadata.extensions.* 실험 네임스페이스의 공식 위치). meta 3 샘플 재변환 HIT 근거: design/rfcs/v2.3.8-metadata-extensions-promotion.md",
  "type": "object",

  "$comment": "schema_version 주석: v2.3.8 은 additive — v2.3.7 스펙이 그대로 로드됨. metadata.extensions.* 은 하위 호환을 위해 수용하되 deprecated (v2.5.0 에서 제거 예정).",

  "required": ["version", "project", "domain", "features"],

  "properties": {
    "version": {
      "type": "string",
      "pattern": "^\\d+\\.\\d+(\\.\\d+)?(-[A-Za-z0-9.-]+)?$",
      "description": "스펙 스키마 버전 (semver). v2.3.8 로더는 >=2.3.0 수용."
    },

    "project": {
      "type": "object",
      "required": ["name", "summary"],
      "properties": {
        "name": {"type": "string"},
        "summary": {"type": "string"},
        "description": {"type": "string"},
        "vision": {"type": "string"},
        "stakeholders": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["role"],
            "properties": {
              "role": {"type": "string"},
              "count": {"type": ["integer", "string"]},
              "interest": {"type": "string"}
            }
          }
        }
      },
      "additionalProperties": true
    },

    "domain": {
      "type": "object",
      "properties": {
        "overview": {"type": "string"},
        "entities": {
          "type": "array",
          "items": {"type": "object"}
        },
        "business_rules": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["id"],
            "properties": {
              "id": {"type": "string", "pattern": "^BR-\\d+$"}
            },
            "additionalProperties": true
          }
        },
        "vocabulary": {"type": ["array", "object"]}
      },
      "additionalProperties": true
    },

    "features": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["id"],
        "properties": {
          "id": {"type": "string", "pattern": "^F-\\d+$"},
          "type": {"type": "string"}
        },
        "additionalProperties": true
      },
      "prefixItems": [
        {
          "description": "Walking Skeleton (v2.3 Runtime-Verified First) — features[0] 은 반드시 type='skeleton'. 첫 피처부터 Gate 5 까지 통과하는 end-to-end 실행 뼈대가 있어야 이후 피처가 그 위에 얹힘.",
          "type": "object",
          "required": ["id", "type"],
          "properties": {
            "id": {"type": "string", "pattern": "^F-\\d+$"},
            "type": {"const": "skeleton"}
          },
          "additionalProperties": true
        }
      ]
    },

    "constraints": {"type": "object"},

    "deliverable": {
      "type": "object",
      "properties": {
        "type": {"type": "string"},
        "platform": {"type": "string"},
        "artifacts": {"type": "array"},
        "entry_points": {"type": "array"},
        "source": {"type": "object"}
      },
      "additionalProperties": true
    },

    "open_questions": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id"],
        "properties": {
          "id": {"type": "string", "pattern": "^OQ-"}
        },
        "additionalProperties": true
      }
    },

    "metadata": {
      "type": "object",
      "description": "v2.3.8 승격 — 8 블록이 metadata.* 1급 필드. metadata.extensions.* 는 하위 호환 수용 (deprecated).",

      "properties": {
        "source": {"type": "object"},
        "traceability": {"type": "object"},
        "conversion": {
          "type": "object",
          "properties": {
            "re_conversion_round": {"type": "integer", "minimum": 1},
            "adapter_version_used": {"type": "string"},
            "host_subtype": {
              "type": "string",
              "enum": [
                "self-bootstrap",
                "host-plugin-build-tool",
                "host-plugin-editor-extension",
                "host-plugin-other",
                "library",
                "saas-service",
                "worker",
                "web-app",
                "game",
                "mixed"
              ],
              "description": "meta 어댑터 v0.2 §3.2 서브타입 판별값 (meta 도메인 전용 초기 — 타 도메인은 'mixed' 또는 omit)"
            },
            "prior_spec_ref": {"type": "string"},
            "backlink_quality_star3_plus": {"type": "string"},
            "backlink_quality_star3_plus_v2": {"type": "string"}
          },
          "additionalProperties": true
        },

        "command_map": {
          "$ref": "#/$defs/command_map"
        },
        "ambient_files": {
          "$ref": "#/$defs/ambient_files"
        },
        "host_binding": {
          "$ref": "#/$defs/host_binding"
        },
        "drift_catalog": {
          "$ref": "#/$defs/drift_catalog"
        },
        "versioning_axes": {
          "$ref": "#/$defs/versioning_axes"
        },
        "contribution_points": {
          "$ref": "#/$defs/contribution_points"
        },
        "preamble_contract": {
          "$ref": "#/$defs/preamble_contract"
        },
        "changelog": {
          "$ref": "#/$defs/changelog"
        },
        "gate_chain": {
          "$ref": "#/$defs/gate_chain"
        },
        "changelog_source_ref": {"type": "string"},

        "extensions": {
          "$comment": "v2.3.7 실험 네임스페이스 — v2.3.8 에서 deprecated. v2.3.8 로더는 같은 8 블록을 여기서 찾으면 metadata.* 로 승격하고 warning 발행. v2.5.0 에서 제거 예정.",
          "type": "object",
          "deprecated": true,
          "properties": {
            "command_map": {"$ref": "#/$defs/command_map"},
            "ambient_files": {"$ref": "#/$defs/ambient_files"},
            "host_binding": {"$ref": "#/$defs/host_binding"},
            "drift_catalog": {"$ref": "#/$defs/drift_catalog"},
            "versioning_axes": {"$ref": "#/$defs/versioning_axes"},
            "contribution_points": {"$ref": "#/$defs/contribution_points"},
            "preamble_contract": {"$ref": "#/$defs/preamble_contract"},
            "changelog": {"$ref": "#/$defs/changelog"},
            "gate_chain": {"$ref": "#/$defs/gate_chain"},
            "agent_permissions": {
              "$comment": "v2.4.0 이관 예정 — v2.3.8 범위 밖. self v2 는 object 형({matrix_source, schema, agents[]}), v2.4.0 에서 array 로 승격 예정.",
              "type": ["array", "object"]
            }
          },
          "additionalProperties": true
        }
      },
      "additionalProperties": true
    }
  },

  "additionalProperties": true,

  "$defs": {
    "command_map": {
      "title": "command_map[] — entry_points 의 명시적 함수 시그니처 선언",
      "description": "P0 MUST-if-present. 3/3 meta HIT. features[].id 와 handler 참조로 연결.",
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id"],
        "properties": {
          "id": {"type": "string", "description": "고유 식별자 — command 와 동일해도 무관"},
          "command": {"type": "string", "description": "호스트 등록 명령 문자열"},
          "handler": {
            "type": "string",
            "description": "features[].id 참조 (예: F-001) 또는 feature 식별 자유 문자열 (예: F-001_init). /harness:check 에서 features[].id 매칭 여부 확인."
          },
          "kind": {
            "type": "string",
            "description": "서브타입별 허용값: self-bootstrap(slash-command/build-step/contract-schema), build-tool(vite-subcommand/rollup-plugin/plugin-factory/webpack-plugin), editor-extension(vscode-command/jetbrains-action/sublime-command). 선택 — 지정 시 /harness:check 가 서브타입별 허용값 체크."
          },
          "source_ref": {"type": "string"},
          "requires_opt_in": {"type": "boolean", "default": false},
          "mode_axis": {
            "type": "string",
            "enum": ["read", "write", "side-effect-free", "mixed"]
          },
          "preamble_required": {"type": "boolean"},
          "gate": {"type": "integer", "description": "gate_chain[].id 참조"},
          "requires_state": {"type": "boolean"}
        },
        "additionalProperties": true
      },
      "uniqueItems": false,
      "$comment": "같은 id 중복 금지 (프로그램적 체크) — JSONSchema 로는 표현 안됨. self-bootstrap 은 kind 대신 preamble_required/gate/requires_state 로 feature 연결 — kind 는 선택."
    },

    "ambient_files": {
      "title": "ambient_files[] — 스펙이 만들거나 읽는 워크스페이스 하위 파일",
      "description": "P0 MUST-if-present. 3/3 meta HIT. glob 은 required=false 만 허용.",
      "type": "array",
      "items": {
        "type": "object",
        "required": ["path", "kind"],
        "properties": {
          "path": {"type": "string", "description": "상대경로 또는 glob"},
          "kind": {
            "type": "string",
            "$comment": "실전 데이터 기반 권장값: ssot / cache / expanded_cache / hash_cache / index_cache / host_config / draft_buffer / lockfile / artifact / log / append_only_log / report / state / shim / agent_definitions / skill_definitions / hook_definitions / other. 서브타입별로 다양 — open-string 유지."
          },
          "owner": {
            "type": "string",
            "enum": ["team", "user", "plugin", "host", "ci"]
          },
          "created_by": {
            "type": "string",
            "description": "features[].id 참조 또는 'user-manual' / 'host' / 'ci'"
          },
          "required": {"type": "boolean", "default": false},
          "sensitive": {"type": "boolean", "default": false},
          "write_policy": {
            "type": "string",
            "enum": ["edit-wins", "overwrite", "append-only", "immutable"]
          },
          "source_ref": {"type": "string"}
        },
        "additionalProperties": true
      }
    },

    "host_binding": {
      "title": "host_binding[] — host 프로그램과의 버전 계약",
      "description": "P0 SHOULD (host-plugin 서브타입 조건부 MUST). 2/2 host-plugin HIT. self-bootstrap 은 N/A.",
      "type": "array",
      "items": {
        "type": "object",
        "required": ["host", "version_range"],
        "properties": {
          "host": {"type": "string", "description": "vite / vscode / rollup / esbuild / webpack / jetbrains / cursor / vscodium / ..."},
          "version_range": {"type": "string", "description": "semver range"},
          "activation_events": {
            "type": "array",
            "items": {"type": "string"}
          },
          "surface": {
            "type": "object",
            "properties": {
              "type": {"type": "string"},
              "registry": {"type": "string"}
            },
            "additionalProperties": true
          },
          "peer_contract": {
            "oneOf": [
              {"type": "null"},
              {
                "type": "object",
                "properties": {
                  "kind": {"type": "string", "enum": ["peerDependencies", "peerDependenciesMeta"]},
                  "strict": {"type": "boolean"}
                },
                "additionalProperties": true
              }
            ]
          },
          "publisher_contract": {
            "oneOf": [
              {"type": "null"},
              {
                "type": "object",
                "properties": {
                  "kind": {"type": "string"},
                  "engines_field": {"type": "string"}
                },
                "additionalProperties": true
              }
            ]
          },
          "best_effort_forks": {
            "type": "array",
            "items": {
              "type": "object",
              "required": ["host"],
              "properties": {
                "host": {"type": "string"},
                "version_range": {"type": "string"},
                "note": {"type": "string"}
              }
            }
          },
          "type_imports": {"type": "array", "items": {"type": "string"}}
        },
        "additionalProperties": true
      }
    },

    "drift_catalog": {
      "title": "drift_catalog[] — 스펙/실제 불일치의 예상 종류 + 처리 정책",
      "description": "P0 MUST-if-present. 3/3 meta HIT.",
      "type": "array",
      "items": {
        "type": "object",
        "required": ["kind", "severity", "action"],
        "properties": {
          "kind": {"type": "string"},
          "detect_by": {"type": "string", "description": "features[].id 또는 'check-time'"},
          "severity": {
            "type": "string",
            "enum": ["info", "low", "medium", "high", "critical"]
          },
          "action": {"type": "string"},
          "source_ref": {"type": "string"}
        },
        "additionalProperties": true
      }
    },

    "versioning_axes": {
      "title": "versioning_axes[] — 독립적으로 버전이 올라가는 축",
      "description": "P0 MUST-if-present. 3/3 meta HIT. 축별 semver + policy.",
      "type": "array",
      "items": {
        "type": "object",
        "required": ["axis", "policy"],
        "properties": {
          "axis": {"type": "string"},
          "current": {"type": "string"},
          "policy": {
            "type": "string",
            "$comment": "권장값: semver_strict / semver_with_migration / semver_with_regenerate / semver_with_pre / stable_contract / append_only_events_log / calver / custom. 도메인별 다양 — open-string 유지."
          },
          "migration_notes": {"type": "string"}
        },
        "allOf": [
          {
            "if": {"properties": {"policy": {"const": "custom"}}},
            "then": {"required": ["migration_notes"]}
          }
        ],
        "additionalProperties": true
      }
    },

    "contribution_points": {
      "title": "contribution_points[] — host 에 기여하는 UI/행동 표면 선언",
      "description": "P1 SHOULD. 3/3 meta HIT. kind 는 서브타입별 다른 집합 허용 — meta 어댑터 v0.2 §4.8 host matrix.",
      "type": "array",
      "items": {
        "type": "object",
        "required": ["kind"],
        "properties": {
          "kind": {
            "type": "string",
            "$comment": "서브타입별 허용값 매트릭스 (meta 어댑터 v0.2 §4.8): self-bootstrap=buildStep/contractSchema/slashCommand, build-tool=pluginHook/cliSubcommand/configSchema, editor-extension=command/keybinding/view/configuration/menus/statusbar/activationEvents/webview/language/debugger. enum 으로 닫지 않고 open-string (서브타입 검증은 /harness:check 에서)."
          },
          "ref": {"type": "string"},
          "values": {"type": "array"},
          "id": {"type": "string"},
          "schema_ref": {"type": "string"},
          "settings_count": {"type": "integer"},
          "source_ref": {"type": "string"}
        },
        "additionalProperties": true
      }
    },

    "preamble_contract": {
      "title": "preamble_contract — 프로세스 시작 시 출력 텍스트 계약",
      "description": "P1 MAY. 3/3 meta HIT. required=true 는 self-bootstrap, false 는 host-plugin 일반.",
      "type": "object",
      "properties": {
        "required": {"type": "boolean"},
        "format": {
          "type": "string",
          "enum": ["multi-line-banner", "single-line-banner", "statusbar-line", "no-output", "3-line", "2-line"],
          "$comment": "실전 self v2 는 '3-line' 사용 (line_1/2/3 3행 banner). multi-line-banner 의 특수 케이스로 취급 — v2.3.9 에서 format 체계 정리 고려."
        },
        "line_1": {"type": "string"},
        "line_2": {"type": "string"},
        "line_3": {"type": "string"},
        "encoding": {"type": "string"},
        "stderr_allowed": {"type": "boolean"},
        "source_ref": {"type": "string"}
      },
      "allOf": [
        {
          "if": {"properties": {"required": {"const": true}}},
          "then": {"required": ["format", "line_1"]}
        }
      ],
      "additionalProperties": true
    },

    "changelog": {
      "title": "changelog[] — 스펙 레벨 변경 이력",
      "description": "P2 MAY. P-24 와 일관. 3/3 meta HIT.",
      "type": "array",
      "items": {
        "type": "object",
        "required": ["version"],
        "properties": {
          "version": {"type": "string"},
          "date": {"type": "string"},
          "note": {"type": "string"},
          "deprecated_in": {
            "type": "string",
            "$comment": "v2.3.9 후보 — OQ-v238-1. 현재는 optional."
          }
        },
        "additionalProperties": true
      }
    },

    "gate_chain": {
      "title": "gate_chain[] — CI/CD 또는 실행 게이트 체인",
      "description": "P1 MAY (조건부). 1/3 full (self-bootstrap), 2/3 partial (host-plugin 은 drift_catalog.action 흡수 허용). 두 스타일 허용: (A) on_fail/blocks 스타일, (B) prerequisite/blocking 스타일 — self v2 가 (B) 사용.",
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "name"],
        "properties": {
          "id": {"type": "integer"},
          "name": {"type": "string"},
          "description": {"type": "string"},
          "on_fail": {
            "type": "string",
            "enum": ["stop", "warn", "continue"]
          },
          "blocks": {
            "type": "array",
            "items": {"type": "integer"}
          },
          "prerequisite": {
            "type": "array",
            "items": {"type": ["integer", "string"]},
            "description": "스타일 B — 이 게이트가 실행되기 전 충족되어야 하는 게이트 id 리스트"
          },
          "blocking": {
            "type": "boolean",
            "description": "스타일 B — true 이면 실패 시 이후 게이트 차단 (on_fail=stop 과 동등)"
          },
          "source_ref": {"type": "string"}
        },
        "anyOf": [
          {"required": ["on_fail"]},
          {"required": ["blocking"]},
          {"required": ["prerequisite"]}
        ],
        "additionalProperties": true
      }
    }
  }
}
