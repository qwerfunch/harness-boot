#!/usr/bin/env node
/* ┌─────────────────────────────────────────────────────────────┐
 * │  Feature Status Auto-Update                                 │
 * │                                                             │
 * │  Runs the project test suite; if it passes, atomically      │
 * │  flips the target feature's `passes` field to true in       │
 * │  feature-list.json. Called from the orchestrator / /start   │
 * │  Step 7 after Gate 4 clears.                                │
 * │                                                             │
 * │  Exit codes: 0 success or skip, 1 test failure or IO error. │
 * │  Related: docs/setup/runtime-guardrails.md, feature-list    │
 * └─────────────────────────────────────────────────────────────┘ */

import { readFileSync, writeFileSync, renameSync } from 'node:fs';
import { spawnSync } from 'node:child_process';
import { dirname, join } from 'node:path';
import { fileURLToPath } from 'node:url';

/* ── Placeholder (substituted by /setup Phase 1) ──────────────── */

const TEST_COMMAND = '{TEST_COMMAND}';

// ⚠️ Fail fast if Phase 1 didn't substitute — otherwise we'd hand
// literal `{TEST_COMMAND}` to a shell and surface an opaque error.
if (TEST_COMMAND.startsWith('{')) {
  console.error('ERROR: update-feature-status {TEST_COMMAND} placeholder not substituted.');
  console.error('Re-run /harness-boot:setup Phase 1 so the stack-specific test command is applied.');
  process.exit(1);
}

/* ── Helpers ─────────────────────────────────────────────────── */

/**
 * Cross-platform shell wrapper. Windows can't parse sh's -c form, so
 * dispatch through cmd.exe with the run-and-exit flag set.
 */
function runShell(cmd, opts = {}) {
  const isWin = process.platform === 'win32';
  return spawnSync(isWin ? 'cmd.exe' : 'sh', [isWin ? '/d/s/c' : '-c', cmd], opts);
}

/* ── Main ────────────────────────────────────────────────────── */

const featId = process.argv[2];
if (!featId) {
  console.error('Usage: update-feature-status.mjs FEAT-XXX');
  process.exit(1);
}

const SCRIPT_DIR = dirname(fileURLToPath(import.meta.url));
const PROJECT_ROOT = join(SCRIPT_DIR, '..');
const FEATURE_LIST = join(PROJECT_ROOT, 'feature-list.json');

let features;
try {
  features = JSON.parse(readFileSync(FEATURE_LIST, 'utf8'));
} catch (e) {
  console.error(`ERROR: ${FEATURE_LIST} is not valid JSON: ${e.message}`);
  process.exit(1);
}

const target = features.find(f => f.id === featId);
if (!target) {
  console.log(`[skip] ${featId} not found in feature-list.json`);
  process.exit(0);
}
if (target.passes !== false) {
  console.log(`[skip] ${featId} is already passes: ${target.passes}`);
  process.exit(0);
}

const testRun = runShell(TEST_COMMAND, { stdio: 'ignore' });
if (testRun.status !== 0) {
  console.log(`[FAIL] Tests did not pass. Cannot mark ${featId} as complete.`);
  process.exit(1);
}

for (const f of features) if (f.id === featId) f.passes = true;

// Atomic write: same-FS rename makes the flip all-or-nothing. The tmp
// sibling lives next to the target so renameSync stays atomic — a
// cross-filesystem rename would silently degrade to copy+unlink.
const tmp = `${FEATURE_LIST}.tmp`;
writeFileSync(tmp, JSON.stringify(features, null, 2) + '\n');
renameSync(tmp, FEATURE_LIST);

console.log(`[OK] ${featId} marked as passes: true`);
