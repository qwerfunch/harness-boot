{
  "name": "harness-boot",
  "version": "0.13.0",
  "description": "Multi-agent development harness for Claude Code. Your AI has speed; we give it direction — through living specs and focused specialist agents.",
  "type": "module",
  "license": "MIT",
  "author": {
    "name": "qwerfunch"
  },
  "homepage": "https://github.com/qwerfunch/harness-boot",
  "repository": {
    "type": "git",
    "url": "https://github.com/qwerfunch/harness-boot.git"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "bin": {
    "harness": "./bin/harness"
  },
  "scripts": {
    "build": "rm -rf dist && tsc -p tsconfig.build.json && npm run bundle",
    "bundle": "esbuild src/cli/harness.ts --bundle --platform=node --format=esm --target=node20 --outfile=dist/cli/harness.bundle.mjs --banner:js=\"import{createRequire as __cr}from 'module';const require=__cr(import.meta.url);\"",
    "prepare": "test -f dist/cli/harness.bundle.mjs || npm run build",
    "test": "vitest run tests/parity --passWithNoTests",
    "test:parity": "vitest run tests/parity --passWithNoTests",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "lint": "eslint 'src/**/*.ts' 'tests/**/*.ts'",
    "lint:fix": "eslint --fix 'src/**/*.ts' 'tests/**/*.ts'",
    "format": "prettier --write 'src/**/*.ts' 'tests/**/*.ts'",
    "format:check": "prettier --check 'src/**/*.ts' 'tests/**/*.ts'"
  },
  "dependencies": {
    "ajv": "^8.20.0",
    "ajv-formats": "^3.0.1",
    "commander": "^12.1.0",
    "smol-toml": "^1.3.1",
    "yaml": "^2.6.1",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "@typescript-eslint/eslint-plugin": "^8.16.0",
    "@typescript-eslint/parser": "^8.16.0",
    "esbuild": "^0.28.0",
    "eslint": "^9.16.0",
    "eslint-config-prettier": "^9.1.0",
    "prettier": "^3.4.1",
    "typescript": "^5.7.2",
    "vitest": "^2.1.6"
  }
}
