{
  "name": "harness-boot",
  "version": "0.2.0",
  "description": "Spec-driven development harness plugin for Claude Code. Single spec.yaml derives .claude/** adapters and .harness/** views; self-hosted via dogfooding.",
  "type": "module",
  "bin": {
    "harness-boot": "./bin/harness-boot"
  },
  "files": [
    "bin/",
    "dist/",
    "schemas/",
    ".claude-plugin/",
    "commands/",
    "agents/",
    "skills/",
    "hooks/",
    "LICENSE",
    "README.md"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "devDependencies": {
    "@types/node": "^20.12.0",
    "@vitest/coverage-v8": "^2.1.0",
    "fast-check": "^3.22.0",
    "typescript": "^5.5.0",
    "vitest": "^2.1.0"
  },
  "license": "Apache-2.0",
  "author": "qwerfunch <jungsoo.kim@doverunner.com>",
  "homepage": "https://github.com/qwerfunch/harness-boot",
  "repository": {
    "type": "git",
    "url": "https://github.com/qwerfunch/harness-boot.git"
  },
  "bugs": {
    "url": "https://github.com/qwerfunch/harness-boot/issues"
  },
  "keywords": [
    "claude-code",
    "plugin",
    "spec-driven-development",
    "tdd",
    "harness"
  ]
}
